{
  "statements": [
    {
      "Resource": {
        "name": "myStash",
        "logical_name": "myStash",
        "token": "pulumi:index:Stash",
        "inputs": [
          [
            "input",
            {
              "String": "test"
            }
          ]
        ]
      }
    },
    {
      "Export": {
        "name": "stashInput",
        "value": {
          "FieldAccess": [
            {
              "Variable": "myStash"
            },
            "input"
          ]
        }
      }
    },
    {
      "Export": {
        "name": "stashOutput",
        "value": {
          "FieldAccess": [
            {
              "Variable": "myStash"
            },
            "output"
          ]
        }
      }
    }
  ]
}